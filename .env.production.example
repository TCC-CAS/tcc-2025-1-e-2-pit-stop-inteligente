# ==========================================================
# .env.production.example — modelo para o deploy em VPS (Docker Compose)
#
# Copie para .env NESTA pasta (junto do docker-compose.yml) e preencha.
# NUNCA versione o .env real — ele contém segredos.
#   cp .env.production.example .env
# ==========================================================

# ---- Ambiente ----
DJANGO_ENV=production

# ---- Django ----
# Gere uma chave forte no servidor:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Domínios/IP que servem a aplicação (vírgula, sem http://).
# Ex.: meudominio.com.br,www.meudominio.com.br   ou   203.0.113.10
ALLOWED_HOSTS=

# ---- HTTPS ----
# Deixe False ENQUANTO acessar só por HTTP (ex.: testando pelo IP do VPS).
# Mude para True depois de configurar o certificado TLS (Let's Encrypt) no nginx.
SECURE_SSL_REDIRECT=False

# ---- CSRF (obrigatório para POST/login) e CORS ----
# Inclua o esquema (http/https). Como o front é servido no mesmo domínio,
# basta listar a própria origem.
# Ex.: https://meudominio.com.br   (ou http://203.0.113.10 enquanto sem TLS)
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=

# ---- Banco de dados (PostgreSQL no contêiner "db") ----
# DB_HOST é forçado para "db" pelo docker-compose — não precisa definir.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=pitstop_db
DB_USER=pitstop
DB_PASSWORD=
DB_PORT=5432

# ---- AbacatePay (cobrança SaaS e de OS) ----
# Em produção use a chave abc_live_* (cobrança real).
ABACATEPAY_API_KEY=
ABACATEPAY_BASE_URL=https://api.abacatepay.com
# Segredo do webhook (configurado no painel da AbacatePay) — valida o HMAC.
# Agora que há URL pública, configure o webhook apontando para:
#   https://SEU_DOMINIO/api/pagamentos/webhook/abacatepay/
ABACATEPAY_WEBHOOK_SECRET=
# Base pública do front (o MESMO domínio do nginx).
# Ex.: https://meudominio.com.br
ABACATEPAY_RETURN_URL_BASE=
# Caminho da página de retorno no front servido pelo nginx (root = front_end/src,
# por isso SEM o prefixo /front_end/src usado no Live Server local).
ABACATEPAY_RETORNO_URL_PATH=/modulos/modulo_oficina/pagamentos/pages/retorno-pagamento.html

# ---- Gunicorn (opcional) ----
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=60
