# ==========================================================
# .env.example — modelo de configuração de ambiente
#
# Copie este arquivo para .env (na mesma pasta back_end/) e
# preencha com os seus valores. NUNCA versione o .env real.
# ==========================================================

# ---- Ambiente ----
# Use "local" no desenvolvimento e "production" no deploy
DJANGO_ENV=local

# ---- Django ----
# Gere uma chave aleatória forte para produção (ex.: Python: `secrets.token_urlsafe(50)`)
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Banco de dados (PostgreSQL local por padrão) ----
DB_ENGINE=django.db.backends.postgresql
DB_NAME=pitstop_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ---- CORS / CSRF ----
# Listas de origens permitidas (separadas por vírgula). Mantenha o front
# (Live Server na :5500) e qualquer outra porta usada listados aqui.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000
# NÃO use True quando o front depende de cookies de sessão.
# O browser exige Access-Control-Allow-Origin: <origin específica>, não *,
# quando o request leva credentials. Deixe False e use a lista acima.
CORS_ALLOW_ALL_ORIGINS=False

# ---- Produção (somente quando DJANGO_ENV=production) ----
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# ---- AbacatePay (cobrança SaaS + cobrança de OS) ----
# Em dev, use a chave abc_dev_* (transações simuladas, nenhuma cobrança real).
# Em produção, troque por abc_live_* gerada no painel da AbacatePay.
ABACATEPAY_API_KEY=
ABACATEPAY_BASE_URL=https://api.abacatepay.com
# Segredo configurado no painel da AbacatePay para validar HMAC do webhook.
# Pode ficar vazio em dev local; obrigatório em produção.
ABACATEPAY_WEBHOOK_SECRET=
# Base do front usada para montar returnUrl/completionUrl do checkout.
# Local: http://localhost:5500 (Live Server). Prod: domínio do front.
ABACATEPAY_RETURN_URL_BASE=http://localhost:5500
# Caminho até a página de retorno. Default funciona quando o Live Server
# serve a partir da raiz do projeto. Se servir direto de front_end/, use
# /src/modulos/modulo_oficina/pagamentos/pages/retorno-pagamento.html
ABACATEPAY_RETORNO_URL_PATH=/front_end/src/modulos/modulo_oficina/pagamentos/pages/retorno-pagamento.html

# ---- Moderação de imagens nos uploads ----
# Por padrão fica "off" — somente validações locais (tamanho, MIME, extensão,
# magic bytes via Pillow). Em produção é possível ligar moderação externa
# para detectar conteúdo inapropriado (nudez, violência):
#   MODERACAO_IMAGEM_PROVEDOR=sightengine
#   SIGHTENGINE_API_USER=...
#   SIGHTENGINE_API_SECRET=...
# Free tier do Sightengine cobre 500 verificações/mês — suficiente para TCC.
MODERACAO_IMAGEM_PROVEDOR=off
MODERACAO_IMAGEM_LIMIAR=0.6
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
